# ─── CheckRada Backend — Environment Variables ────────────────────────────────
# Copy to .env and fill in values before running locally.
# On Vercel: add via the Environment Variables dashboard — NEVER commit .env to Git.

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=your_64_char_random_secret_here

# Admin JWT — separate secret from user JWT (different trust tier)
# Generate: openssl rand -base64 64
ADMIN_JWT_SECRET=your_64_char_admin_secret_here

# ─── WhatsApp OTP (Meta Cloud API) ────────────────────────────────────────────
# From: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_waba_id
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token
WHATSAPP_OTP_TEMPLATE_NAME=checkrada_otp

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://api.checkrada.co.ke

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CSRF_SECRET=your_32_char_random_secret_here

# ─── Admin seed ───────────────────────────────────────────────────────────────
# Set BEFORE running npm run db:seed — remove IMMEDIATELY after
ADMIN_SEED_PASSWORD=

# ─── Safaricom Daraja (M-Pesa payments) ───────────────────────────────────────
# From: developer.safaricom.co.ke → Apps → Your App
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here

# Your M-Pesa Paybill business short code
DARAJA_BUSINESS_SHORT_CODE=your_paybill_shortcode_here

# STK Push passkey — from Daraja portal → your app → Lipa Na M-Pesa Online
DARAJA_PASSKEY=your_stk_passkey_here

# B2C credentials — from Safaricom Business Portal → M-Pesa → B2C
DARAJA_INITIATOR_NAME=your_initiator_name_here
# RSA-encrypted initiator password (generated once with Safaricom public cert)
DARAJA_SECURITY_CREDENTIAL=your_encrypted_security_credential_here

# Random secret embedded in Daraja callback URLs to authenticate Safaricom requests
# Generate: openssl rand -hex 32
DARAJA_CALLBACK_SECRET=your_32_char_hex_secret_here

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# ─── Removed providers ────────────────────────────────────────────────────────
# Paystack       ← removed; replaced by Daraja
# Africa's Talking ← removed; replaced by Meta WhatsApp Cloud API
# Kopokopo       ← removed; never integrated