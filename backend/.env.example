# ─── CheckRada Backend v8 — Environment Variables ────────────────────────────
# Copy to .env and fill in values before running locally.
# On Railway: add via the Variables tab — NEVER commit .env to Git.

# ─── Database ─────────────────────────────────────────────────────────────────
# Auto-set by Railway PostgreSQL plugin
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ─── Redis ────────────────────────────────────────────────────────────────────
# Auto-set by Railway Redis plugin
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=your_64_char_random_secret_here

# ─── WhatsApp OTP (Meta Cloud API) ────────────────────────────────────────────
# From: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_waba_id
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token
WHATSAPP_OTP_TEMPLATE_NAME=checkrada_otp

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://api.checkrada.co.ke

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CSRF_SECRET=your_32_char_random_secret_here

# ─── Admin seed ───────────────────────────────────────────────────────────────
# Set BEFORE running npm run db:seed — remove IMMEDIATELY after
ADMIN_SEED_PASSWORD=

# ─── Payment (UNDECIDED — do not fill until provider chosen) ─────────────────
# PAYMENT_API_KEY=
# PAYMENT_API_SECRET=
# PAYMENT_WEBHOOK_SECRET=

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# ─── REMOVED — no longer needed ───────────────────────────────────────────────
# AT_USERNAME        ← Africa's Talking — deleted
# AT_API_KEY         ← Africa's Talking — deleted
# AT_SENDER_ID       ← Africa's Talking — deleted
# MPESA_*            ← Daraja — keep structure, payment provider TBD
