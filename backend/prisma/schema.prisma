generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  name            String?
  kycStatus       KycStatus @default(PENDING)
  role            UserRole  @default(USER)
  balanceKes      Decimal   @default(0) @db.Decimal(15,2)
  bonusBalanceKes Decimal   @default(0) @db.Decimal(15,2)
  rewardBalance   Decimal   @default(0) @db.Decimal(15,2)
  suspended       Boolean   @default(false)
  agreedToTerms   Boolean   @default(false)
  confirmedAge    Boolean   @default(false)
  integrityScore  Int       @default(100)
  referralCode    String?   @unique
  referredBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  orders              Order[]
  positions           Position[]
  transactions        Transaction[]
  markets             Market[]          @relation("MarketCreator")
  challengesAsA       MarketChallenge[] @relation("ChallengeUserA")
  challengesAsB       MarketChallenge[] @relation("ChallengeUserB")
  challengesAsReferee MarketChallenge[] @relation("ChallengeReferee")
  proposals           MarketProposal[]
  bounties            CreatorBounty[]
  notifications       Notification[]
  referralsGiven      Referral[]        @relation("ReferralReferrer")
  referralsReceived   Referral[]        @relation("ReferralReferee")

  @@map("users")
}

model AdminAccount {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  createdBy    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())

  activityLogs AdminActivityLog[]

  @@map("admin_accounts")
}

model AdminActivityLog {
  id        String       @id @default(cuid())
  adminId   String
  admin     AdminAccount @relation(fields: [adminId], references: [id])
  action    String
  target    String?
  detail    String?
  ipAddress String?
  createdAt DateTime     @default(now())

  @@map("admin_activity_logs")
}

model OtpCode {
  phone     String   @id
  code      String
  attempts  Int      @default(0)
  expiresAt DateTime

  @@map("otp_codes")
}

model Market {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String
  category    Category
  imageUrl    String?
  sourceNote  String?
  creatorId   String
  creator     User         @relation("MarketCreator", fields: [creatorId], references: [id])
  status      MarketStatus @default(OPEN)
  outcome     Outcome?
  yesPool     Decimal      @default(1000) @db.Decimal(15,2)
  noPool      Decimal      @default(1000) @db.Decimal(15,2)
  closesAt    DateTime
  resolvedAt  DateTime?
  totalVolume Decimal      @default(0) @db.Decimal(15,2)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  orders    Order[]
  positions Position[]
  bounty    CreatorBounty?

  @@map("markets")
}

model MarketChallenge {
  id              String           @id @default(cuid())
  question        String
  accessCode      String           @unique
  userAId         String
  userA           User             @relation("ChallengeUserA", fields: [userAId], references: [id])
userBId         String?
  userB           User?            @relation("ChallengeUserB", fields: [userBId], references: [id])
  refereeId       String?
  referee         User?            @relation("ChallengeReferee", fields: [refereeId], references: [id])
  refereeAccepted Boolean          @default(false)
  stakePerPerson  Decimal          @db.Decimal(15,2)
  totalPool       Decimal          @default(0) @db.Decimal(15,2)
  validatorType   ValidatorType    @default(MUTUAL)
  status          ChallengeStatus  @default(PENDING_JOIN)
  resolution      ChallengeOutcome?
  eventExpiresAt  DateTime
  disputeDeadline DateTime?
  resolvedAt      DateTime?
  userAConfirm    ChallengeOutcome?
  userBConfirm    ChallengeOutcome?
  isPublic        Boolean          @default(false)
  feePercent      Decimal          @default(5) @db.Decimal(5,2)
  platformFeeKes  Decimal          @default(0) @db.Decimal(15,2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  transactions Transaction[]

  @@map("market_challenges")
}

model MarketProposal {
  id               String         @id @default(cuid())
  proposerId       String
  proposer         User           @relation(fields: [proposerId], references: [id])
  question         String
  category         Category
  resolutionSource String
  whyCareNote      String?
  status           ProposalStatus @default(PENDING)
  slug             String?        @unique
  rewardPaidAt     DateTime?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("market_proposals")
}

model CreatorBounty {
  id            String    @id @default(cuid())
  marketId      String    @unique
  market        Market    @relation(fields: [marketId], references: [id])
  creatorId     String
  creator       User      @relation(fields: [creatorId], references: [id])
  tradeVolume   Decimal   @default(0) @db.Decimal(15,2)
  bountyEarned  Decimal   @default(0) @db.Decimal(15,2)
  paidOut       Decimal   @default(0) @db.Decimal(15,2)
  lastPaidAt    DateTime?
  active        Boolean   @default(false)
  deactivatedAt DateTime?

  @@map("creator_bounties")
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  marketId          String
  market            Market      @relation(fields: [marketId], references: [id])
  side              Side
  amountKes         Decimal     @db.Decimal(15,2)
  netAmountKes      Decimal     @db.Decimal(15,2)
  forecastingFeeKes Decimal     @default(0) @db.Decimal(15,2)
  bonusUsedKes      Decimal     @default(0) @db.Decimal(15,2)
  shares            Decimal     @db.Decimal(15,6)
  pricePerShare     Decimal     @db.Decimal(10,6)
  status            OrderStatus @default(FILLED)
  creatorAttribution String?
  createdAt         DateTime    @default(now())

  @@map("orders")
}

model Position {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  marketId    String
  market      Market   @relation(fields: [marketId], references: [id])
  side        Side
  shares      Decimal  @db.Decimal(15,6)
  avgPrice    Decimal  @db.Decimal(10,6)
  realizedPnl Decimal  @default(0) @db.Decimal(15,2)
  updatedAt   DateTime @updatedAt

  @@unique([userId, marketId, side])
  @@map("positions")
}

model Transaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  challengeId String?
  challenge   MarketChallenge? @relation(fields: [challengeId], references: [id])
  type        TransactionType
  amountKes   Decimal         @db.Decimal(15,2)
  balAfter    Decimal         @db.Decimal(15,2)
  mpesaRef    String?         @unique
  phone       String?
  status      TxStatus        @default(PENDING)
  description String?
  createdAt   DateTime        @default(now())

  @@map("transactions")
}
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@map("notifications")
}

model CarouselSlide {
  id        String    @id @default(cuid())
  tag       String?
  title     String
  subtitle  String?
  imageUrl  String?
  bgColour  String    @default("#1a1035")
  ctaText   String?
  ctaLink   String?
  active    Boolean   @default(true)
  expiresAt DateTime?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("carousel_slides")
}

model ReferralConfig {
  id                String   @id @default("singleton")
  active            Boolean  @default(true)
  referrerRewardKes Decimal  @default(50)  @db.Decimal(10,2)
  refereeMatchKes   Decimal  @default(100) @db.Decimal(10,2)
  minDepositKes     Decimal  @default(100) @db.Decimal(10,2)
  updatedAt         DateTime @updatedAt

  @@map("referral_config")
}

model Referral {
  id                String         @id @default(cuid())
  referrerId        String
  referrer          User           @relation("ReferralReferrer", fields: [referrerId], references: [id])
  refereeId         String
  referee           User           @relation("ReferralReferee", fields: [refereeId], references: [id])
  status            ReferralStatus @default(PENDING)
  referrerRewardKes Decimal        @default(0) @db.Decimal(10,2)
  refereeRewardKes  Decimal        @default(0) @db.Decimal(10,2)
  rewardPaidAt      DateTime?
  createdAt         DateTime       @default(now())

  @@unique([refereeId])
  @@map("referrals")
}

model DataApplication {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  email          String
  mobile         String
  city           String
  country        String
  orgName        String
  orgType        String
  jobTitle       String
  website        String?
  planInterest   String
  useCase        String
  useDescription String
  dataVolume     String?
  refNumber      String   @unique
  status         String   @default("PENDING")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum Category {
  GENERAL
  POLITICS
  ECONOMY
  ENTERTAINMENT
  WEATHER
  TECH
  FRIENDS
}

enum MarketStatus {
  OPEN
  PAUSED
  CLOSED
  RESOLVED
  CANCELLED
}

enum Outcome {
  YES
  NO
}

enum Side {
  YES
  NO
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
}

enum ValidatorType {
  MUTUAL
  REFEREE
  TIMER
}

enum ChallengeStatus {
  PENDING_PAYMENT
  PENDING_JOIN
  ACTIVE
  PENDING_RESOLUTION
  DISPUTED
  RESOLVED
  CANCELLED
}

enum ChallengeOutcome {
  USER_A
  USER_B
  TIE
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReferralStatus {
  PENDING
  QUALIFIED
  REWARDED
  FLAGGED
}

enum TxStatus {
  PENDING
  SUCCESS
  FAILED
}

enum NotificationType {
  MARKET_RESOLVED
  MARKET_CLOSING_SOON
  MARKET_PROBABILITY_SHIFT
  CHALLENGE_OPPONENT_STAKED
  CHALLENGE_RESOLUTION_WINDOW
  CHALLENGE_RESOLUTION_WARNING
  REFEREE_NOMINATED
  DEPOSIT_CONFIRMED
  WITHDRAWAL_PROCESSED
  REFERRAL_REWARD_CREDITED
  NEW_MARKET_IN_CATEGORY
  PROMO
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRADE_BUY
  TRADE_SELL
  PAYOUT
  REFUND
  CHALLENGE_STAKE
  CHALLENGE_PAYOUT
  SUGGESTION_REWARD
  CREATOR_BOUNTY
  REFERRAL_REWARD
  BONUS_USED
}
